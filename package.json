{
    "type": "module",
    "version": "0.1.0",
    "scripts": {
        "start": "tsc --build --verbose && node dist/index.js",
        "test": "echo there are no tests for yarik currently",
        "dev": "npm run build:esbuild --no-bundle && node bundle.cjs | pino-pretty -c",
        "build:esbuild": "esbuild build.ts --bundle --outfile=build.js --platform=node --format=esm --packages=external && node build.js",
        "build:rolldown": "rolldown -c rolldown.config.mjs",
        "deps-check": "taze major",
        "deploy": "tsc --build && node dist/deploy.js",
        "generate-db": "prisma generate"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bufferutil": "^4.1.0",
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "lru-cache": "^11.3.6",
        "openai": "^6.36.0",
        "pino": "^10.3.1"
    },
    "optionalDependencies": {
        "@antfu/eslint-config": "^8.2.0",
        "eslint": "^10.3.0",
        "postject": "^1.0.0-alpha.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@prisma/extension-accelerate": "^3.0.1",
        "@types/pg": "^8.20.0",
        "esbuild": "^0.28.0",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.8.0",
        "rolldown": "1.0.0-beta.51",
        "taze": "^19.11.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
